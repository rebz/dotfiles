#################################################################
### GIT
#################################################################

# Pushes all the code up in the current directory
function pushme {

    branch=`git branch | grep "*"`

    params=''

    for i in $*;
    do
        params=" $params $i"
    done

    params=$(echo $params | sed 's,^ *,,; s, *$,,')

    git add --all
    git commit -m "$params"
    git push origin ${branch/* /}
}

rebase() {
    if [ $1 ]
        then
            git pull origin $1 --rebase
        else
            echo "Missing branch to rebase from"
    fi
}

commit() {

    echo What JIRA issue are you working on?
    read issue

    echo What did you work on?
    read message

    if [ ! -z "$issue" ]
    then
        issue="$issue : "
    fi

    branch=`git branch | grep "*"`

    git add --all
    git commit -m "$issue$message"
    git push origin ${branch/* /}
}

deleteBranches() {
    git branch --merged origin/develop | grep -v master | grep -v develop | grep -v dev | xargs git branch -d
}





#################################################################
### NVM
#################################################################

nvmset() {
    echo "$1" > .nvmrc
}

nvmdefault() {
    nvm alias default $1
}

port() {
    if [ $1 ]
    then
        sudo -v;
        echo PIDs:
        sudo lsof -i tcp:$1 | grep -v "Google"
        echo "\n"
        echo Listeners:
        sudo netstat -vanp tcp | grep $1
    else
        echo Must supply a port.
    fi
}

kport() {
    if [ $1 ]
    then
        sudo -v;
        pidsFound=($(sudo lsof -i tcp:$1 | grep -v "Google" | awk 'NR>1{ print $2 }' | sort -u))
        if (( ${#pidsFound[@]} ))
        then
            for pid in "${pidsFound[@]}"
            do
                echo Killing $pid
                sudo echo $pidsFound | xargs kill -9
            done
        else
            echo Did not find anything running on $1
        fi
    else
        echo Must supply a port.
    fi
}


# mobile - Toggle remote access to this machine from your phone
#
# Usage:
#   mobile        Run once to enable, run again to disable
#
# What it does:
#   ON:  Starts Tailscale VPN (if not already running),
#        enables macOS SSH (Remote Login), and creates
#        a detached tmux session named "mobile".
#        Prints the Tailscale IP to connect to.
#
#   OFF: Kills the "mobile" tmux session, disables SSH,
#        and cleans up the state file.
#
# From your phone (using Termius, Blink, etc.):
#   1. SSH into <tailscale-ip> on port 22
#   2. Run: tmux attach -t mobile
#
# External files:
#   /tmp/.mobile_mode   Tracks on/off state. Cleared on reboot.
#
# Dependencies:
#   tailscale, tmux, sudo (for systemsetup)
mobile() {
    local state_file="/tmp/.mobile_mode"

    if [ -f "$state_file" ]; then
        # Turn off
        echo "Disabling mobile mode..."

        tmux kill-session -t mobile 2>/dev/null && echo "  tmux session killed" || echo "  tmux session already gone"
        sudo systemsetup -setremotelogin off 2>/dev/null && echo "  SSH disabled"

        rm "$state_file"
        echo "Mobile mode OFF"
    else
        # Turn on
        echo "Enabling mobile mode..."

        # Tailscale
        if ! tailscale status &>/dev/null; then
            tailscale up && echo "  Tailscale connected"
        else
            echo "  Tailscale already running"
        fi

        # SSH
        sudo systemsetup -setremotelogin on 2>/dev/null && echo "  SSH enabled"

        # tmux
        if ! tmux has-session -t mobile 2>/dev/null; then
            tmux new-session -d -s mobile && echo "  tmux session 'mobile' started"
        else
            echo "  tmux session 'mobile' already exists"
        fi

        touch "$state_file"
        echo "Mobile mode ON"
        echo "  Connect to: $(tailscale ip -4)"
        echo "  Attach with: tmux attach -t mobile"
    fi
}


#################################################################
### Other
#################################################################

xdebug() {
   iniFileLocation="/usr/local/etc/php/7.1/conf.d/ext-xdebug.ini";

   currentLine=`cat $iniFileLocation | grep xdebug.so`

   if [[ $currentLine =~ ^#zend_extension ]];
   then
      sed -i -e 's/^zend_extension/zend_extension/g' $iniFileLocation
      echo "xdebug is now active";
   else
      sed -i -e 's/^#zend_extension/zend_extension/g' $iniFileLocation
      echo "xdebug is now inactive";
   fi
}

# user passes a single argument that defines the tab title for the terminal
# "Tab Title"
tt() {
    echo -ne "\033]0;$1\007"
}